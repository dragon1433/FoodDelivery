<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/nav_graph"
app:startDestination="@id/loginFragment" >

<!-- Login -->
<fragment
    android:id="@+id/loginFragment"
    android:name="com.fooddelivery.app.ui.screens.login.LoginFragment"
    android:label="Login" >

    <action
        android:id="@+id/action_loginFragment_to_mainFragment"
        app:destination="@id/mainFragment"
        app:popUpTo="@id/loginFragment"
        app:popUpToInclusive="true" />
    <action
        android:id="@+id/action_loginFragment_to_registerFragment"
        app:destination="@id/registerFragment" />

</fragment>

<!-- Register -->
<fragment
    android:id="@+id/registerFragment"
    android:name="com.fooddelivery.app.ui.screens.register.RegisterFragment"
    android:label="Register" />

<!-- Home -->
<fragment
    android:id="@+id/mainFragment"
    android:name="com.fooddelivery.app.ui.screens.home.MainFragment"
    android:label="Home" >

    <action
        android:id="@+id/action_mainFragment_to_restaurantDetailFragment"
        app:destination="@id/restaurantDetailFragment" />
    <action
        android:id="@+id/action_main_fragment_to_search_fragment"
        app:destination="@id/searchFragment" />

</fragment>

<!-- Cart -->
<fragment
    android:id="@+id/cartFragment"
    android:name="com.fooddelivery.app.ui.screens.cart.CartFragment"
    android:label="Cart" >

    <action
        android:id="@+id/action_cart_fragment_to_checkout_fragment"
        app:destination="@id/checkoutFragment" />

</fragment>

<!-- Order -->
<fragment
    android:id="@+id/orderFragment"
    android:name="com.fooddelivery.app.ui.screens.order.OrderFragment"
    android:label="Order" >

    <action
        android:id="@+id/action_orderFragment_to_orderDetailFragment"
        app:destination="@id/orderDetailFragment" />

</fragment>

<!-- Order Detail -->
<fragment
    android:id="@+id/orderDetailFragment"
    android:name="com.fooddelivery.app.ui.screens.order.OrderDetailFragment"
    android:label="Order Detail" />

<!-- Profile -->
<fragment
    android:id="@+id/profileFragment"
    android:name="com.fooddelivery.app.ui.screens.profile.ProfileFragment"
    android:label="Profile" >

    <action
        android:id="@+id/action_profile_fragment_to_address_fragment"
        app:destination="@id/addressFragment" />

</fragment>

<!-- Restaurant Detail -->
<fragment
    android:id="@+id/restaurantDetailFragment"
    android:name="com.fooddelivery.app.ui.screens.restaurant.RestaurantDetailFragment"
    android:label="Restaurant Detail" >

    <action
        android:id="@+id/action_restaurantDetailFragment_to_checkoutFragment"
        app:destination="@id/checkoutFragment" />

</fragment>

<!-- Search -->
<fragment
    android:id="@+id/searchFragment"
    android:name="com.fooddelivery.app.ui.screens.search.SearchFragment"
    android:label="Search" />

<!-- Checkout -->
<fragment
    android:id="@+id/checkoutFragment"
    android:name="com.fooddelivery.app.ui.screens.checkout.CheckoutFragment"
    android:label="Checkout" >

    <action
        android:id="@+id/action_checkoutFragment_to_addressFragment"
        app:destination="@id/addressFragment" />

</fragment>

<!-- Address Management -->
<fragment
    android:id="@+id/addressFragment"
    android:name="com.fooddelivery.app.ui.screens.address.AddressFragment"
    android:label="Address Management" />
</navigation>