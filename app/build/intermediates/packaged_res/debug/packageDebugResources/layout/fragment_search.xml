<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="10dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/back" />

        <EditText
            android:id="@+id/edit_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/search_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="@string/home_search_hint"
            android:textSize="14sp"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <ImageView
            android:id="@+id/btn_clear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:padding="10dp"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            android:contentDescription="@string/cart_clear" />
    </LinearLayout>

    <!-- Search Results -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Restaurant Search Results -->
            <TextView
                android:id="@+id/text_restaurant_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Related Restaurants"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_restaurants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false" />

            <!-- Dish Search Results -->
            <TextView
                android:id="@+id/text_dish_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Related Dishes"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_dishes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
