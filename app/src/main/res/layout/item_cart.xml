<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- 商品图片 -->
        <ImageView
            android:id="@+id/image_cart_item"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_home"
            android:contentDescription="商品图片" />

        <!-- 商品信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginLeft="12dp"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/text_cart_item_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="商品名称"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_cart_item_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥28.0"
                android:textSize="14sp"
                android:textColor="#FF6B35"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/btn_cart_decrease"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_remove"
                    android:padding="4dp" />

                <TextView
                    android:id="@+id/text_cart_quantity"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/btn_cart_increase"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_add"
                    android:padding="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 删除按钮 -->
        <ImageView
            android:id="@+id/btn_delete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_remove"
            android:padding="6dp"
            android:layout_gravity="top"
            android:contentDescription="删除" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
